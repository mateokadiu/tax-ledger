{
  "name": "@tax-ledger/fonoa",
  "version": "1.1.0",
  "description": "Fonoa Tax calculation response adapter for @tax-ledger/core. Maps result.items[].tax_breakdown[] (EU VAT / GST) into a normalized TaxInput.",
  "license": "MIT",
  "author": "Mateo Kadiu",
  "repository": {
    "type": "git",
    "url": "https://github.com/mateokadiu/tax-ledger.git",
    "directory": "packages/fonoa"
  },
  "keywords": ["tax", "fonoa", "vat", "gst", "adapter", "tax-ledger"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint TBD'",
    "test": "vitest run"
  },
  "dependencies": {
    "@tax-ledger/core": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "publishConfig": { "access": "public" }
}
