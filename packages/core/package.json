{
  "name": "@tax-ledger/core",
  "version": "1.0.0",
  "description": "Pure line-item tax splitter + reconciliation engine. Decimal.js math, largest-remainder allocation, integer-cent ledger output that sums back without drift.",
  "license": "MIT",
  "author": "Mateo Kadiu",
  "repository": {
    "type": "git",
    "url": "https://github.com/mateokadiu/tax-ledger.git",
    "directory": "packages/core"
  },
  "keywords": ["tax", "ledger", "sales-tax", "avalara", "taxjar", "stripe-tax", "reconciliation", "accounting"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint TBD'",
    "test": "vitest run"
  },
  "dependencies": {
    "decimal.js": "^10.4.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "fast-check": "^3.23.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "publishConfig": { "access": "public" }
}
